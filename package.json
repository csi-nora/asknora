{
  "name": "csi-nora",
  "version": "4.2.0",
  "description": "CSI Nora — Singtel Enterprise Portfolio Advisor (deployment bundle)",
  "private": true,
  "scripts": {
    "ng": "ng",
    "gateway": "node server/gateway.cjs",
    "start:prod": "node server/production.cjs",
    "prod": "node server/production.cjs",
    "demo": "bash scripts/demo-local-ubuntu.sh",
    "docker:up": "docker compose -f deploy/docker/docker-compose.yml up --build -d",
    "docker:down": "docker compose -f deploy/docker/docker-compose.yml down",
    "package:prod": "node scripts/package-production.mjs",
    "build:vm": "node scripts/build-for-vm.mjs",
    "build": "ng build --configuration=production",
    "test": "ng test",
    "test:uat": "ng test --no-watch --browsers=ChromeHeadless --include=**/deployment-environment.service.spec.ts --include=**/backend-llm-urls.spec.ts"
  },
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "http-proxy-middleware": "^3.0.5",
    "pdfjs-dist": "^3.11.174",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.4.2"
  }
}
