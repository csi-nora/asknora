# ── Compute scaling: cpu | gpu | npu | auto ──────────────────────────────────
# Switch with: .\scripts\set_accel.ps1 -Device cpu|gpu|npu
ACCEL_DEVICE=auto
# Ollama: -1 = all layers on GPU, 0 = CPU only
OLLAMA_NUM_GPU=0
# OpenVINO target for NPU/GPU embeddings (CPU|GPU|NPU|AUTO)
OPENVINO_DEVICE=AUTO
OVMS_URL=http://localhost:9000

# ── Cloud LLM API keys (optional — Ollama used as fallback) ─────────────────
# Responsible AI / ops path: keys live on the bridge (env / .env — NEVER commit).
# Prefer a rotating pool: comma-separated list, or primary + secondary.
# Rotation triggers on HTTP 401 / 403 / 429 (quota / auth failures).
OPENAI_API_KEY=
OPENAI_API_KEY_SECONDARY=
OPENAI_API_KEYS=
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_SECONDARY=
ANTHROPIC_API_KEYS=
HF_API_KEY=
HF_API_KEY_SECONDARY=
HF_API_KEYS=
GOOGLE_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=

# Default provider order: openai,anthropic,google,groq,ollama
LLM_PROVIDER_ORDER=openai,anthropic,google,groq,ollama
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_ANTHROPIC=claude-3-5-haiku-20241022
LLM_MODEL_GOOGLE=gemini-2.0-flash
LLM_MODEL_GROQ=llama-3.1-8b-instant
LLM_MODEL_OLLAMA=llama3.1:8b

# ── Local Ollama ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HOST_PORT=11434

# ── Reverse proxy (single entry point) ───────────────────────────────────────
# DEFAULT: bind 0.0.0.0 so the demo is reachable on the LAN at
# http://<LAN-IP>:PROXY_HTTP_PORT. Port 9090 avoids Windows reserved 80/8080.
# Set PROXY_BIND_HOST=127.0.0.1 to lock to localhost only. All OTHER services
# bind 127.0.0.1 (loopback) and are reached only through the proxy — do not
# expose Ollama/bridge/DBs to the LAN.
PROXY_BIND_HOST=0.0.0.0
PROXY_HTTP_PORT=9090
BRIDGE_HOST_PORT=8090

# ── Vector stores ────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_HOST_PORT=8000

# ── Redis / Postgres ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST_PORT=6379
POSTGRES_DSN=postgresql://sandbox:sandbox_dev_password@localhost:5432/ai_sandbox
POSTGRES_USER=sandbox
POSTGRES_PASSWORD=sandbox_dev_password
POSTGRES_DB=ai_sandbox
POSTGRES_HOST_PORT=5432

# ── Observability ────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-ecosystem-sandbox
LANGSMITH_TRACING=true

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_HOST_PORT=3000
LANGFUSE_DB_PASSWORD=langfuse_dev_password
LANGFUSE_NEXTAUTH_SECRET=change-me-use-openssl-rand-hex-32
LANGFUSE_SALT=change-me-use-openssl-rand-hex-32

PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# ── Memory (Zep cloud — optional) ────────────────────────────────────────────
ZEP_API_KEY=
ZEP_PROJECT_ID=

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL_OPENAI=text-embedding-3-small
EMBEDDING_MODEL_LOCAL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_BGE=BAAI/bge-small-en-v1.5

# ── Demo interfaces ──────────────────────────────────────────────────────────
JUPYTER_HOST_PORT=8888
JUPYTER_TOKEN=sandbox
STREAMLIT_HOST_PORT=8501

# ── Security / Responsible AI ────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
LOG_LEVEL=INFO
# Key rotation: see OPENAI_API_KEYS / ANTHROPIC_API_KEYS / HF_API_KEYS above.
# Status (no secrets): GET http://localhost:9090/sandbox/guardrails/status
# Ollama needs no keys; output guardrails still apply when chat goes via /sandbox.
