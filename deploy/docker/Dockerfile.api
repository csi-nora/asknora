# CSI Nora LLM gateway (production container)
FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY server/gateway.cjs server/gateway.cjs

ENV NODE_ENV=production
ENV PORT=3456
EXPOSE 3456

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3456/api/health || exit 1

CMD ["node", "server/gateway.cjs"]
